<% content_for :title, "Edit Subject | QPaper" %>

<section class="app-shell">
  <%= render "sidebar", active: :manage_subjects %>

  <main class="app-main">
    <div class="app-content">
      <article class="panel" style="max-width: 600px; margin: 2rem auto;">
        <div class="panel-header">
          <h3>Edit Subject</h3>
        </div>

        <%= form_with url: update_subject_path(@subject), method: :patch, local: true do |f| %>
          <div class="stack p-6">
            <div class="field">
              <label>Subject Name</label>
              <input type="text" name="name" value="<%= @subject.name %>" class="ui-input" required>
            </div>
            <div class="field mt-4">
              <label>Subject Code</label>
              <input type="text" name="code" value="<%= @subject.code %>" class="ui-input" required>
            </div>
            
            <div class="btn-row mt-6">
              <button type="submit" class="btn">Update Subject</button>
              <%= link_to "Cancel", pages_manage_subjects_path, class: "btn-ghost" %>
            </div>
          </div>
        <% end %>
      </article>
    </div>
  </main>
</section>