<% content_for :title, "Generate Paper | QPaper" %>

<section class="app-shell">
  <%= render "sidebar", active: :generate_paper %>

  <main class="app-main">
    <%= render "topbar",
      title: "Generate Paper",
      subtitle: "Set the paper profile and generate quickly.",
      eyebrow: "Generator",
      action_label: "View History",
      action_path: pages_generated_papers_path %>

    <div class="app-content">
      <article class="panel">
        <div class="panel-header">
          <div>
            <h3>Algorithm Configuration</h3>
            <p class="subtle-text">Configure the paper and run generation.</p>
          </div>
          <span class="badge">Ready to Run</span>
        </div>

        <form class="stack" data-demo-loading="true" data-loading-text="Generating paper..." data-loading-delay="1500" data-redirect-url="<%= pages_view_paper_path %>">
          <div class="field-grid">
            <div class="field">
              <label for="paper_department">Department</label>
              <select id="paper_department">
                <option>BCA</option>
                <option>B.Sc Computer Science</option>
                <option>BBA</option>
                <option>B.Com</option>
              </select>
            </div>
            <div class="field">
              <label for="paper_semester">Semester</label>
              <select id="paper_semester">
                <option>Semester 1</option>
                <option>Semester 2</option>
                <option>Semester 3</option>
                <option>Semester 4</option>
              </select>
            </div>
            <div class="field">
              <label for="paper_exam_type">Exam Type</label>
              <select id="paper_exam_type">
                <option>First Internal</option>
                <option>Second Internal</option>
                <option>Model Exam</option>
                <option>End Semester</option>
              </select>
            </div>
            <div class="field">
              <label for="paper_subject">Target Subject</label>
              <select id="paper_subject">
                <option>Data Structures (CS101)</option>
                <option>Operating Systems (CS102)</option>
              </select>
            </div>
          </div>

          <div class="field">
            <label for="paper_title">Examination Title</label>
            <input id="paper_title" type="text" value="Mid-Term Examination 2026">
          </div>

          <div class="list-grid">
            <div class="panel">
              <div class="panel-headline">
                <div>
                  <h4>Difficulty Distribution</h4>
                  <p class="subtle-text">Balance sections by difficulty.</p>
                </div>
              </div>

              <div class="stack">
                <div class="field">
                  <label for="easy_count">Section A | Easy</label>
                  <input id="easy_count" type="number" value="5">
                </div>
                <div class="field">
                  <label for="medium_count">Section B | Medium</label>
                  <input id="medium_count" type="number" value="3">
                </div>
                <div class="field">
                  <label for="hard_count">Section C | Hard</label>
                  <input id="hard_count" type="number" value="2">
                </div>
              </div>
            </div>

            <div class="panel">
              <div class="panel-headline">
                <div>
                  <h4>Generation Notes</h4>
                  <p class="subtle-text">Optional notes.</p>
                </div>
              </div>

              <div class="field">
                <label for="paper_notes">Notes</label>
                <textarea id="paper_notes" placeholder="Add paper notes."></textarea>
              </div>
            </div>
          </div>

          <div class="btn-row">
            <button type="submit" class="btn" data-loading-button="true">
              <span data-loading-label="true">Generate Paper</span>
            </button>
            <button type="button" class="btn-ghost" data-toast-trigger="generate-toast">Save Template</button>
          </div>
        </form>
      </article>
    </div>
  </main>
</section>

<div id="generate-toast" class="toast">Paper template saved for reuse.</div>
