<% content_for :title, "Generate Paper | QPaper" %>

<section class="app-shell">
  <%= render "sidebar", active: :generate_paper %>

  <main class="app-main">
    <%= render "topbar",
      title: "Generate Paper",
      subtitle: "Set the paper profile and generate quickly.",
      eyebrow: "Generator",
      action_label: "View History",
      action_path: pages_generated_papers_path %>

    <div class="app-content">
      <article class="panel">
        <div class="panel-header">
          <div>
            <h3>Algorithm Configuration</h3>
            <p class="subtle-text">Configure the paper and run generation.</p>
          </div>
          <span class="badge">Ready to Run</span>
        </div>

        <%# Form updated to use subject_id for controller compatibility %>
        <form action="<%= create_paper_path %>" method="POST" class="mt-8 space-y-6">
          <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
          
          <div class="field-grid">
            <div class="field">
              <label for="paper_exam_type">Exam Type</label>
              <select id="paper_exam_type" name="exam_type" class="ui-select">
                <option>First Internal</option>
                <option>Second Internal</option>
                <option>Model Exam</option>
                <option>End Semester</option>
              </select>
            </div>
            <div class="field">
              <label for="paper_subject">Target Subject</label>
              <select id="paper_subject" name="subject_id" class="ui-select" required>
                <option value="">Select Subject</option>
                <% Subject.all.each do |s| %>
                  <option value="<%= s.id %>"><%= s.name %> (<%= s.code %>)</option>
                <% end %>
              </select>
            </div>
          </div>

          <div class="field">
            <label for="paper_title">Examination Title</label>
            <input id="paper_title" name="title" type="text" class="ui-input" value="Mid-Term Examination 2026" required>
          </div>

          <div class="list-grid">
            <div class="panel">
              <div class="panel-headline p-4">
                <div>
                  <h4>Difficulty Distribution</h4>
                  <p class="subtle-text">Balance sections by difficulty.</p>
                </div>
              </div>

              <div class="stack p-4">
                <div class="field">
                  <label for="easy_count">Section A | Easy Questions</label>
                  <input id="easy_count" name="easy_count" type="number" class="ui-input" value="5" min="0">
                </div>
                <div class="field">
                  <label for="medium_count">Section B | Medium Questions</label>
                  <input id="medium_count" name="medium_count" type="number" class="ui-input" value="3" min="0">
                </div>
                <div class="field">
                  <label for="hard_count">Section C | Hard Questions</label>
                  <input id="hard_count" name="hard_count" type="number" class="ui-input" value="2" min="0">
                </div>
              </div>
            </div>

            <div class="panel">
              <div class="panel-headline p-4">
                <div>
                  <h4>Generation Notes</h4>
                  <p class="subtle-text">Optional instructions for the paper.</p>
                </div>
              </div>

              <div class="field p-4">
                <label for="paper_notes">Notes</label>
                <textarea id="paper_notes" name="notes" class="ui-textarea" placeholder="e.g. Answer all questions in Part A."></textarea>
              </div>
            </div>
          </div>

          <div class="btn-row">
            <button type="submit" class="btn">
              <span>Generate Paper</span>
            </button>
            <button type="button" class="btn-ghost">Save Template</button>
          </div>
        </form>
      </article>
    </div>
  </main>
</section>