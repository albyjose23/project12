<% content_for :title, "Generate Paper | QPaper" %>

<section class="app-shell">
  <%= render "sidebar", active: :generate_paper %>

  <main class="app-main">
    <%= render "topbar",
      title: "Generate Paper",
      subtitle: "Set the paper profile and generate quickly.",
      eyebrow: "Generator",
      action_label: "View History",
      action_path: pages_generated_papers_path %>

    <div class="app-content">
      <article class="panel">
        <div class="panel-header">
          <div>
            <h3>Paper Details</h3>
            <p class="subtle-text">Enter the paper information and section-wise question counts in one place.</p>
          </div>
          <span class="badge">Ready to Run</span>
        </div>

        <form action="<%= create_paper_path %>" method="POST" class="mt-8 space-y-6">
          <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
          
          <div class="field-grid">
            <div class="field">
              <label for="paper_title">Question Paper Title</label>
              <input id="paper_title" name="title" type="text" class="ui-input" value="Mid-Term Examination 2026" required>
            </div>
            <div class="field">
              <label for="paper_exam_type">Exam Type</label>
              <select id="paper_exam_type" name="exam_type" class="ui-select">
                <option>First Internal</option>
                <option>Second Internal</option>
                <option>Model Exam</option>
                <option>End Semester</option>
              </select>
            </div>
            <div class="field">
              <label for="paper_subject">Target Subject</label>
              <select id="paper_subject" name="subject_id" class="ui-select" required>
                <option value="">Select Subject</option>
                <% Subject.all.each do |s| %>
                  <option value="<%= s.id %>"><%= s.name %> (<%= s.code %>)</option>
                <% end %>
              </select>
            </div>
            <div class="field">
              <label for="paper_duration">Exam Duration</label>
              <input id="paper_duration" name="duration" type="text" class="ui-input" value="3 Hours" required>
            </div>
            <div class="field">
              <label for="paper_total_marks">Total Marks</label>
              <input id="paper_total_marks" name="total_marks" type="number" class="ui-input" value="44" min="1" required>
            </div>
          </div>

          <div class="list-grid">
            <div class="panel">
              <div class="panel-headline p-4">
                <div>
                  <h4>Question Selection</h4>
                  <p class="subtle-text">Choose exactly how many questions you want from each marks section.</p>
                </div>
              </div>

              <div class="stack p-4">
                <div class="field">
                  <label for="section_a_count">2 Marks Questions</label>
                  <input id="section_a_count" name="section_a_count" type="number" class="ui-input" value="5" min="0">
                </div>
                <div class="field">
                  <label for="section_b_count">6 Marks Questions</label>
                  <input id="section_b_count" name="section_b_count" type="number" class="ui-input" value="3" min="0">
                </div>
                <div class="field">
                  <label for="section_c_count">8 Marks Questions</label>
                  <input id="section_c_count" name="section_c_count" type="number" class="ui-input" value="2" min="0">
                </div>
                <p class="subtle-text"> The entered marks must be matching with total marks .</p>
              </div>
            </div>

            <div class="panel">
              <div class="panel-headline p-4">
                <div>
                  <h4>Instructions</h4>
                  <p class="subtle-text">Add any directions you want printed on the question paper.</p>
                </div>
              </div>

              <div class="field p-4">
                <label for="paper_instructions">Paper Instructions</label>
                <textarea id="paper_instructions" name="instructions" class="ui-textarea" placeholder="e.g. Answer all questions in Section A."></textarea>
              </div>
            </div>
          </div>

          <div class="btn-row">
            <button type="submit" class="btn">
              <span>Generate Paper</span>
            </button>
          </div>
        </form>
      </article>
    </div>
  </main>
</section>
