<% content_for :title, "Import Questions | QPaper" %>

<section class="app-shell">
  <%= render "sidebar", active: :question_bank %>

  <main class="app-main">
    <%= render "topbar",
        title: "Bulk Import",
        subtitle: "Upload your questions via CSV or Word file.",
        eyebrow: "Repository" %>

    <div class="app-content">
      <article class="panel">
        <div class="panel-header">
          <div>
            <h3>Question Loader</h3>
            <p class="subtle-text">Fill your bank instantly.</p>
          </div>
          <span class="badge">CSV / DOCX</span>
        </div>

        <div class="p-6">
          <%# Ensure the URL matches your POST route helper %>
          <%= form_with url: import_questions_path, method: :post, local: true, html: { multipart: true } do |f| %>
            
            <div class="field">
              <label for="subject_id">Target Subject</label>
              <%# Pulling real subjects from your database %>
              <%= f.collection_select :subject_id, @subjects, :id, :name, 
                  { prompt: "Select Subject" }, 
                  { class: "ui-select", required: true, id: "subject_id" } %>
            </div>

            <div class="field">
              <label for="csv_file">Select CSV or Word File</label>
              <input type="file" name="file" id="csv_file" accept=".csv,.docx" class="ui-input" required>
              <p class="subtle-text mt-2">Accepted files: <strong>.csv</strong> and <strong>.docx</strong>. CSV needs the <strong>content</strong> header. Word files can follow the college bank style with title lines, <strong>UNIT 1</strong>, <strong>SECTION A -2 Marks</strong>, <strong>SECTION B-6 Marks</strong>, and <strong>SECTION C-8 Marks</strong>. Multi-line program questions are merged correctly during import.</p>
            </div>

            <div class="btn-row">
              <button type="submit" class="btn">Start Import Process</button>
              <%= link_to "Cancel", pages_question_bank_path, class: "btn-ghost" %>
            </div>

          <% end %>
        </div>
      </article>

      <article class="panel mt-8">
        <div class="panel-header">
          <div>
            <h3>Expected CSV Format</h3>
            <p class="subtle-text">Use these column headers exactly.</p>
          </div>
        </div>
        <div class="p-6">
          <pre class="surface-inset p-4 rounded text-sm overflow-x-auto">
content,section,unit
"What is a variable?",A,1
"Explain recursion.",B,2
"Solve the traveling salesman problem.",C,5</pre>
        </div>
      </article>

      <article class="panel mt-8">
        <div class="panel-header">
          <div>
            <h3>Expected Word Format</h3>
            <p class="subtle-text">Use DOCX with one question per line under each section.</p>
          </div>
        </div>
          <div class="p-6">
          <pre class="surface-inset p-4 rounded text-sm overflow-x-auto">
VI SEM BCA
PHP & MYSQL QUESTION BANK

UNIT 1
SECTION A -2 Marks
1.What is PHP?
What is XAMPP?

SECTION B-6 Marks
1.Explain the features of PHP.

SECTION C-8 Marks
Write a complete PHP program to:
Connect to MySQL
Create a table
Insert records
Display records</pre>
        </div>
      </article>
    </div>
  </main>
</section>
