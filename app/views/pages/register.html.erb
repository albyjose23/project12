<% content_for :title, "Register | QPaper" %>
<% content_for :body_class, "auth-body" %>

<section class="auth-shell">
  <div class="hero-panel">
    <div class="stack">
      <div class="eyebrow">Faculty onboarding</div>
      <h1 class="hero-title">Launch a polished paper workflow from day one.</h1>
      <p class="hero-copy">Create a faculty account and start managing papers faster.</p>
      <div class="quick-list">
        <div class="quick-item">
          <div>
            <div class="strong">Department Setup</div>
            <div class="muted">Map faculty to department and semester.</div>
          </div>
          <span class="badge">Step 1</span>
        </div>
        <div class="quick-item">
          <div>
            <div class="strong">Question Management</div>
            <div class="muted">Organize questions by unit.</div>
          </div>
          <span class="badge">Step 2</span>
        </div>
        <div class="quick-item">
          <div>
            <div class="strong">Paper Publishing</div>
            <div class="muted">Generate and print papers.</div>
          </div>
          <span class="badge">Step 3</span>
        </div>
      </div>
    </div>
  </div>

  <div class="auth-panel">
    <div class="brand-lockup">
      <div class="brand-mark">Q</div>
      <div class="brand-copy">
        <h1>QPaper Suite</h1>
        <p>Create your account</p>
      </div>
    </div>

    <%= form_with model: @user || User.new, url: pages_register_path, class: "stack" do |form| %>
      <div class="field-grid">
        <div class="field">
          <label for="register_name">Full Name</label>
          <%= form.text_field :name, id: "register_name", placeholder: "Ms. Priya", required: true %>
        </div>
        <div class="field">
          <label for="register_email">College Email</label>
          <%= form.email_field :email, id: "register_email", placeholder: "faculty@college.edu", required: true %>
        </div>
      </div>

      <div class="field-grid">
        <div class="field">
          <label for="register_department">Department</label>
          <%= form.select :department, [["Select department", ""], "BCA", "B.Sc Computer Science", "BBA", "B.Com"], {}, { id: "register_department", required: true } %>
        </div>
        <div class="field">
          <label for="register_role">Role</label>
          <%= form.select :role, [["Select role", ""], "Professor", "Assistant Professor", "Exam Cell Coordinator"], {}, { id: "register_role", required: true } %>
        </div>
      </div>

      <div class="field-grid">
        <div class="field">
          <label for="register_password">Password</label>
          <%= form.password_field :password, id: "register_password", placeholder: "Create a secure password", required: true %>
        </div>
        <div class="field">
          <label for="register_confirm">Confirm Password</label>
          <%= form.password_field :password_confirmation, id: "register_confirm", placeholder: "Repeat password", required: true %>
        </div>
      </div>

      <div class="btn-row">
        <%= form.submit "Create Account", class: "btn" %>
        <a href="<%= pages_login_path %>" class="btn-ghost">Back to Login</a>
      </div>
    <% end %>
  </div>
</section>
