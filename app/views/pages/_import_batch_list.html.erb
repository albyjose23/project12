<article class="panel">
  <div class="panel-header">
    <div>
      <h3><%= title %></h3>
      <p class="subtle-text"><%= subtitle %></p>
    </div>
    <span class="badge"><%= badge_text %></span>
  </div>

  <div class="quick-list">
    <% if import_batches.any? %>
      <% import_batches.each do |batch| %>
        <div class="quick-item-manage">
          <div class="item-body">
            <div class="item-meta">
              <% batch[:subject_codes].each do |code| %>
                <span class="strong text-white"><%= code %></span>
              <% end %>
              <span class="subtle-text"><%= batch[:question_count] %> Questions</span>
              <% if batch[:imported_at].present? %>
                <span class="subtle-text"><%= batch[:imported_at].strftime("%d %b %Y %I:%M %p") %></span>
              <% end %>
              <span class="subtle-text">Imported File</span>
            </div>
            <div class="item-content text-white">
              <%= batch[:file_name] %>
            </div>
          </div>

          <div class="item-actions">
            <%= link_to delete_import_batch_path(group_key: batch[:group_key]),
                        data: { "turbo-method": :delete, "turbo-confirm": "Delete all questions from this imported file?" },
                        class: "action-icon delete",
                        title: "Delete Imported File" do %>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="p-8 text-center muted">
        <p><%= empty_message %></p>
      </div>
    <% end %>
  </div>
</article>
