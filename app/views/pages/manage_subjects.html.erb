<% content_for :title, "Manage Subjects | QPaper" %>

<section class="app-shell">
  <%= render "sidebar", active: :manage_subjects %>

  <main class="app-main">
    <%= render "topbar",
      title: "Manage Subjects",
      subtitle: "Add and organize subjects by semester.",
      eyebrow: "Syllabus",
      action_label: "Question Bank",
      action_path: pages_question_bank_path %>

    <div class="app-content page-grid">
      <article class="panel">
        <div class="panel-header">
          <div>
            <h3>Add New Subject</h3>
            <p class="subtle-text">Keep department and semester aligned.</p>
          </div>
          <span class="badge">Form</span>
        </div>

        <%# Form pointed to add_subject_path %>
        <%= form_with url: add_subject_path, method: :post, local: true do |f| %>
          <div class="field-grid">
            <div class="field">
              <label for="subject_department">Department</label>
              <select id="subject_department" name="department">
                <option>BCA</option>
                <option>B.Sc Computer Science</option>
                <option>BBA</option>
                <option>B.Com</option>
              </select>
            </div>
            <div class="field">
              <label for="subject_semester">Semester</label>
              <select id="subject_semester" name="semester">
                <% (1..6).each do |i| %><option>Semester <%= i %></option><% end %>
              </select>
            </div>
            <div class="field">
              <label for="subject_name">Subject Name</label>
              <input id="subject_name" name="name" type="text" placeholder="Data Structures" required>
            </div>
            <div class="field">
              <label for="subject_code">Subject Code</label>
              <input id="subject_code" name="code" type="text" placeholder="CS101" required>
            </div>
          </div>

          <div class="btn-row">
            <button type="submit" class="btn">Add Subject</button>
            <button type="button" class="btn-ghost">Import Syllabus</button>
          </div>
        <% end %>
      </article>

      <article class="panel">
        <div class="panel-header">
          <div>
            <h3>Current Subjects</h3>
            <p class="subtle-text">Current subject list.</p>
          </div>
        </div>

        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Code</th>
                <th>Subject</th>
                <th>Semester</th>
                <th class="text-right">Action</th>
              </tr>
            </thead>
            <tbody>
              <%# DYNAMIC LOOPING THROUGH YOUR DATABASE %>
              <% Subject.all.order(code: :asc).each do |s| %>
                <tr>
                  <td class="strong"><%= s.code %></td>
                  <td><%= s.name %></td>
                  <td class="muted"><%= s.try(:semester) || "N/A" %></td>
                  <td class="text-right">
                    <button type="button" class="table-action">Edit</button>
                  </td>
                </tr>
              <% end %>
              <% if Subject.none? %>
                <tr><td colspan="4" class="text-center muted">No subjects added yet.</td></tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </article>
    </div>
  </main>
</section>

<div id="subject-toast" class="toast">Subject saved successfully.</div>