<% content_for :title, "Login | QPaper" %>
<% content_for :body_class, "auth-body" %>

<section class="auth-shell">
  <div class="hero-panel">
    <div class="stack">
      <div class="eyebrow">Professional paper automation</div>
      <h1 class="hero-title">Black and white, built to command attention.</h1>
      <p class="hero-copy">QPaper keeps subject planning, question curation, and paper generation in one clean interface.</p>
      <div class="chip-row">
        <span class="chip">Clean monochrome UI</span>
        <span class="chip">Interactive controls</span>
        <span class="chip">Faster faculty workflow</span>
      </div>
    </div>

    <div class="hero-metrics">
      <div class="metric">
        <strong>12</strong>
        <span class="muted">Active departments</span>
      </div>
      <div class="metric">
        <strong>450+</strong>
        <span class="muted">Questions maintained</span>
      </div>
      <div class="metric">
        <strong>84</strong>
        <span class="muted">Papers produced</span>
      </div>
    </div>
  </div>

  <div class="auth-panel">
    <div class="brand-lockup">
      <div class="brand-mark">Q</div>
      <div class="brand-copy">
        <h1>QPaper Suite</h1>
        <p>Faculty sign in</p>
      </div>
    </div>

    <div class="stack">
      <div>
        <h2 class="section-title">Welcome back</h2>
        <p class="subtle-text">Sign in to manage papers and questions.</p>
      </div>

      <%= form_with url: pages_login_path, scope: :session, class: "stack" do |form| %>
        <div class="field">
          <label for="login_email">Email Address</label>
          <%= form.email_field :email, id: "login_email", placeholder: "faculty@college.edu", required: true %>
        </div>

        <div class="field">
          <label for="login_password">Password</label>
          <%= form.password_field :password, id: "login_password", placeholder: "Enter your password", required: true %>
        </div>

        <div class="btn-row">
          <%= form.submit "Sign In", class: "btn" %>
          <a href="<%= pages_register_path %>" class="btn-ghost">Create Account</a>
        </div>
      <% end %>

      <p class="auth-switch">
        New faculty member?
        <%= link_to "Register here", pages_register_path, class: "btn-link" %>
      </p>
    </div>
  </div>
</section>
