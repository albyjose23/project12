<% content_for :title, "Generated Papers | QPaper" %>

<section class="app-shell">
  <%= render "sidebar", active: :generated_papers %>

  <main class="app-main">
    <%= render "topbar",
      title: "Generated Papers",
      subtitle: "Review recent output, reopen papers, and keep print-ready versions accessible.",
      eyebrow: "History",
      action_label: "Generate New Paper",
      action_path: pages_generate_paper_path %>

    <div class="app-content page-grid">
      <article class="panel">
        <div class="panel-header">
          <div>
            <h3>Recent Paper Runs</h3>
            <p class="subtle-text">A polished paper archive with fast access to previews.</p>
          </div>
        </div>

        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Date</th>
                <th>Exam Title</th>
                <th>Subject</th>
                <th>Status</th>
                <th class="text-right">Action</th>
              </tr>
            </thead>
            <tbody>
              <% if @papers.any? %>
                <% @papers.each do |paper| %>
                  <tr>
                    <td class="muted"><%= paper.created_at.strftime("%b %d, %Y") %></td>
                    <td class="strong"><%= paper.title.presence || "Untitled Paper" %></td>
                    <td><%= paper.subject.name %> (<%= paper.subject.code %>)</td>
                    <td><span class="badge">Saved</span></td>
                    <td class="text-right">
                      <div class="flex justify-end gap-3">
                        <%= link_to "Open", view_paper_path(id: paper.id), class: "table-action" %>
                        <%# NEW: DELETE ACTION %>
                        <%= button_to "Delete", delete_paper_path(id: paper.id), method: :delete, data: { confirm: "Are you sure?" }, class: "table-action text-red-500" %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              <% else %>
                <tr>
                  <td colspan="5" class="muted text-center py-8">No generated papers yet.</td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </article>
    </div>
  </main>
</section>