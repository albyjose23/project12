<% content_for :title, "Question Bank | QPaper" %>

<section class="app-shell">
  <%= render "sidebar", active: :question_bank %>

  <main class="app-main">
    <%= render "topbar",
      title: "Question Bank",
      subtitle: "Curate and review unit-wise questions.",
      eyebrow: "Repository",
      action_label: "Manage Subjects",
      action_path: pages_manage_subjects_path %>

    <div class="app-content content-grid">
      
      <%# --- LEFT COLUMN: ADD NEW QUESTION FORM --- %>
      <article class="panel">
        <div class="panel-header">
          <div>
            <h3>Add New Question</h3>
            <p class="subtle-text">Enter details manually or use CSV import.</p>
          </div>
          <span class="badge">Input</span>
        </div>

        <%= form_with url: add_question_path, method: :post, local: true do |f| %>
          <div class="field-grid">
            <div class="field">
              <label for="qb_subject">Subject</label>
              <select id="qb_subject" name="subject_id" class="ui-select" required>
                <option value="">Select Subject</option>
                <% Subject.all.order(name: :asc).each do |s| %>
                  <option value="<%= s.id %>"><%= s.name %> (<%= s.code %>)</option>
                <% end %>
              </select>
            </div>

            <div class="field">
              <label for="qb_unit">Unit</label>
              <select id="qb_unit" name="unit" class="ui-select">
                <option value="1">Unit 1</option>
                <option value="2">Unit 2</option>
                <option value="3">Unit 3</option>
                <option value="4">Unit 4</option>
                <option value="5">Unit 5</option>
              </select>
            </div>

            <div class="field">
              <label for="qb_difficulty">Difficulty</label>
              <select id="qb_difficulty" name="difficulty" class="ui-select">
                <option value="Easy">Easy</option>
                <option value="Medium">Medium</option>
                <option value="Hard">Hard</option>
              </select>
            </div>

            <div class="field">
              <label for="qb_marks">Marks</label>
              <input id="qb_marks" name="marks" type="number" value="10" class="ui-input">
            </div>
          </div>

          <div class="field mt-4">
            <label for="qb_question">Question Text</label>
            <textarea id="qb_question" name="content" placeholder="Type the question content here..." class="ui-textarea" required rows="5"></textarea>
          </div>

          <div class="btn-row mt-6">
            <button type="submit" class="btn">Save Question</button>
            <%= link_to "Import CSV", import_questions_page_path, class: "btn-ghost" %>
          </div>
        <% end %>
      </article>

      <%# --- RIGHT COLUMN: MANAGE RECENT ENTRIES --- %>
<article class="panel">
  <div class="panel-header">
    <div>
      <h3>Recent Entries</h3>
      <p class="subtle-text">Review, edit, or remove questions.</p>
    </div>
  </div>

  <div class="quick-list">
    <% if Question.any? %>
      <% Question.includes(:subject).order(created_at: :desc).limit(10).each do |q| %>
        <div class="quick-item-manage">
          <div class="item-body">
            <div class="item-meta">
              <span class="strong text-white"><%= q.subject.code %></span>
              <span class="subtle-text">Unit <%= q.unit.presence || 'N/A' %></span>
              <span class="badge" data-difficulty="<%= q.difficulty.downcase %>">
                <%= q.difficulty %>
              </span>
            </div>
            <div class="item-content text-white">
              <%= truncate(q.content, length: 80) %>
            </div>
          </div>

          <div class="item-actions">
            <%# Link to Edit Page %>
            <%= link_to edit_question_path(q), class: "action-icon edit", title: "Edit" do %>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"></path></svg>
            <% end %>
            
            <%# FIXED DELETE: Added turbo attributes to prevent Routing Error %>
            <%= link_to delete_question_path(q), 
                        data: { "turbo-method": :delete, "turbo-confirm": "Are you sure you want to delete this question?" }, 
                        class: "action-icon delete", 
                        title: "Delete" do %>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="p-8 text-center muted">
        <p>No questions found.</p>
      </div>
    <% end %>
  </div>
</article>

    </div>
  </main>
</section>

<%# Toast Notifications %>
<% if flash[:notice] %>
  <div id="question-toast" class="toast show"><%= flash[:notice] %></div>
<% end %>
<% if flash[:alert] %>
  <div id="question-toast" class="toast show" style="background: #ef4444;"><%= flash[:alert] %></div>
<% end %>

<style>
  /* Difficulty Badges */
  .badge[data-difficulty="easy"] { background: #dcfce7; color: #166534; }
  .badge[data-difficulty="medium"] { background: #fef9c3; color: #854d0e; }
  .badge[data-difficulty="hard"] { background: #fee2e2; color: #991b1b; }

  /* Manage List Styles */
  .quick-item-manage {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 16px;
    border-bottom: 1px solid #e2e8f0;
    transition: background 0.2s;
  }

  .quick-item-manage:hover {
    background: #171819;
  }

  .item-body {
    flex: 1;
    padding-right: 15px;
  }

  .item-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 4px;
    font-size: 13px;
  }

  .item-content {
    font-size: 14px;
    color: #475569;
    line-height: 1.4;
  }

  .item-actions {
    display: flex;
    gap: 8px;
  }

  .action-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    color: #64748b;
    border: 1px solid #e2e8f0;
    transition: all 0.2s;
  }

  .action-icon.edit:hover {
    color: #3b82f6;
    background: #eff6ff;
    border-color: #bfdbfe;
  }

  .action-icon.delete:hover {
    color: #ef4444;
    background: #fef2f2;
    border-color: #fecaca;
  }

  /* Input Theme Fix */
  .ui-select, .ui-input, .ui-textarea {
    width: 100%;
    padding: 10px;
    border-radius: 6px;
    border: 1px solid #cbd5e1;
    background: white;
    font-size: 14px;
  }
  .text-blue { 
    color: #3b82f6 !important; 
  }
  .text-blue:hover { 
    text-decoration: underline; 
    color: #2563eb !important; 
  }

  .text-red { 
    color: #ef4444 !important; 
  }
  .text-red:hover { 
    text-decoration: underline; 
    color: #dc2626 !important; 
  }

  /* If you are using the ICON version I gave you previously, use these: */
  .action-icon.edit { color: #3b82f6; }
  .action-icon.delete { color: #ef4444; }
</style>