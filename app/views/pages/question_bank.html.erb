<% content_for :title, "Question Bank | QPaper" %>

<section class="app-shell">
  <%= render "sidebar", active: :question_bank %>

  <main class="app-main">
    <%= render "topbar",
      title: "Question Bank",
      subtitle: "Curate and review unit-wise questions.",
      eyebrow: "Repository",
      action_label: "Manage Subjects",
      action_path: pages_manage_subjects_path %>

    <div class="app-content content-grid">
      <div class="marks-entry-grid">
        <% Question.section_options.each do |section, label, attributes| %>
          <article class="panel mark-panel">
            <div class="panel-header">
              <div>
                <h3><%= label %> Questions</h3>
                <p class="subtle-text">Add questions directly to Section <%= section %>.</p>
              </div>
              <span class="badge">Section <%= section %></span>
            </div>

            <%= form_with url: add_question_path, method: :post, local: true do |f| %>
              <input type="hidden" name="marks" value="<%= attributes[:marks] %>">
              <input type="hidden" name="difficulty" value="<%= attributes[:difficulty] %>">

              <div class="field-grid">
                <div class="field">
                  <label for="subject_<%= section.downcase %>">Subject</label>
                  <select id="subject_<%= section.downcase %>" name="subject_id" class="ui-select" required>
                    <option value="">Select Subject</option>
                    <% @subjects.each do |subject| %>
                      <option value="<%= subject.id %>"><%= subject.name %> (<%= subject.code %>)</option>
                    <% end %>
                  </select>
                </div>

                <div class="field">
                  <label for="unit_<%= section.downcase %>">Unit</label>
                  <select id="unit_<%= section.downcase %>" name="unit" class="ui-select">
                    <option value="1">Unit 1</option>
                    <option value="2">Unit 2</option>
                    <option value="3">Unit 3</option>
                    <option value="4">Unit 4</option>
                    <option value="5">Unit 5</option>
                  </select>
                </div>
              </div>

              <div class="field mt-4">
                <label for="question_<%= section.downcase %>">Question Text</label>
                <textarea id="question_<%= section.downcase %>" name="content" placeholder="Type the question content here..." class="ui-textarea" required rows="5"></textarea>
              </div>

              <div class="btn-row mt-6">
                <button type="submit" class="btn">Save <%= label %> Question</button>
              </div>
            <% end %>
          </article>
        <% end %>
      </div>

      <article class="panel">
        <div class="panel-header">
          <div>
            <h3>Bulk Import</h3>
            <p class="subtle-text">Import many questions at once from CSV or DOCX.</p>
          </div>
          <span class="badge">Import</span>
        </div>

        <div class="p-6">
          <p class="subtle-text">Use `content` as the required header. You can supply `section`, `marks`, `difficulty`, and `unit`. Imported questions are separated from typed questions for easier editing and deletion.</p>
          <div class="btn-row mt-6">
            <%= link_to "Import CSV", import_questions_page_path, class: "btn" %>
          </div>
        </div>
      </article>

      <%= render "question_list",
          title: "Typed Questions",
          subtitle: "Questions added directly on this page.",
          badge_text: "#{@typed_questions.count} Total",
          questions: @typed_questions,
          empty_message: "No typed questions found." %>

      <%= render "import_batch_list",
          title: "Imported Questions",
          subtitle: "Questions added through CSV or DOCX import.",
          badge_text: "#{@imported_batches.count} Files",
          import_batches: @imported_batches,
          empty_message: "No imported questions found." %>

    </div>
  </main>
</section>

<%# Toast Notifications %>
<% if flash[:notice] %>
  <div id="question-toast" class="toast show"><%= flash[:notice] %></div>
<% end %>
<% if flash[:alert] %>
  <div id="question-toast" class="toast show" style="background: #ef4444;"><%= flash[:alert] %></div>
<% end %>

<style>
  .marks-entry-grid {
    display: grid;
    gap: 1.5rem;
  }

  .mark-panel {
    margin-bottom: 0;
  }

  /* Difficulty Badges */
  .badge[data-difficulty="easy"] { background: #dcfce7; color: #166534; }
  .badge[data-difficulty="medium"] { background: #fef9c3; color: #854d0e; }
  .badge[data-difficulty="hard"] { background: #fee2e2; color: #991b1b; }

  /* Manage List Styles */
  .quick-item-manage {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 16px;
    border-bottom: 1px solid #e2e8f0;
    transition: background 0.2s;
  }

  .quick-item-manage:hover {
    background: #171819;
  }

  .item-body {
    flex: 1;
    padding-right: 15px;
  }

  .item-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 4px;
    font-size: 13px;
  }

  .item-content {
    font-size: 14px;
    color: #475569;
    line-height: 1.4;
  }

  .item-actions {
    display: flex;
    gap: 8px;
  }

  .action-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    color: #64748b;
    border: 1px solid #e2e8f0;
    transition: all 0.2s;
  }

  .action-icon.edit:hover {
    color: #3b82f6;
    background: #eff6ff;
    border-color: #bfdbfe;
  }

  .action-icon.delete:hover {
    color: #ef4444;
    background: #fef2f2;
    border-color: #fecaca;
  }

  /* Input Theme Fix */
  .ui-select, .ui-input, .ui-textarea {
    width: 100%;
    padding: 10px;
    border-radius: 6px;
    border: 1px solid #cbd5e1;
    background: white;
    font-size: 14px;
  }
  .text-blue { 
    color: #3b82f6 !important; 
  }
  .text-blue:hover { 
    text-decoration: underline; 
    color: #2563eb !important; 
  }

  .text-red { 
    color: #ef4444 !important; 
  }
  .text-red:hover { 
    text-decoration: underline; 
    color: #dc2626 !important; 
  }

  /* If you are using the ICON version I gave you previously, use these: */
  .action-icon.edit { color: #3b82f6; }
  .action-icon.delete { color: #ef4444; }
</style>
