<section class="app-shell">
  <%= render "sidebar", active: :question_bank %>
  <main class="app-main">
    <article class="panel" style="max-width: 800px; margin: 2rem auto;">
      <div class="panel-header">
        <h3>Edit Question</h3>
      </div>
      
      <%= form_with url: update_question_path(@question), method: :patch, local: true do %>
        <div class="p-6">
          <div class="field-grid">
            <div class="field">
              <label>Subject</label>
              <select name="subject_id" class="ui-select" required>
                <% @subjects.each do |subject| %>
                  <option value="<%= subject.id %>" <%= "selected" if subject.id == @question.subject_id %>>
                    <%= subject.name %> (<%= subject.code %>)
                  </option>
                <% end %>
              </select>
            </div>
            <div class="field">
              <label>Unit</label>
              <input type="number" name="unit" value="<%= @question.unit %>" class="ui-input">
            </div>
          </div>

          <div class="field mt-4">
            <label>Question Section</label>
            <div class="section-radio-grid">
              <% Question.section_options.each do |section, label, attributes| %>
                <label class="section-radio-card">
                  <input type="radio" name="marks" value="<%= attributes[:marks] %>" <%= "checked" if @question.section_name == section %>>
                  <span><strong><%= label %></strong> | Section <%= section %></span>
                </label>
              <% end %>
            </div>
          </div>

          <div class="field mt-4">
            <label>Question Content</label>
            <textarea name="content" class="ui-textarea" rows="6"><%= @question.content %></textarea>
          </div>

          <div class="btn-row mt-6">
            <button type="submit" class="btn">Update Question</button>
            <%# FIXED CANCEL: Links back to Question Bank %>
            <%= link_to "Cancel", pages_question_bank_path, class: "btn-ghost" %>
          </div>
        </div>
      <% end %>
    </article>
  </main>
</section>

<style>
  .section-radio-grid {
    display: grid;
    gap: 0.75rem;
  }

  .section-radio-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 1rem;
    border: 1px solid #cbd5e1;
    border-radius: 0.75rem;
    background: #fff;
  }
</style>
