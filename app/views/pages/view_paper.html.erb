<% content_for :title, "View Paper | QPaper" %>

<section class="print-shell">
  <div class="paper-actions no-print">
    <%= link_to "Back to Dashboard", pages_dashboard_path, class: "btn-ghost interactive" %>
    <button type="button" class="btn interactive" onclick="window.print()">Print or Save PDF</button>
  </div>

  <article class="paper-frame">
    <div class="paper-top-band" aria-hidden="true"></div>

    <div class="paper-head">
      <div class="institution-brand">
        <div class="brand-copy">
          <div class="institution-name">CHRIST COLLEGE OF SCIENCE AND MANAGEMENT</div>
          <div class="institution-detail">(Affiliated to Bengaluru North University, Recognized by Govt. of Karnataka)</div>
          <div class="institution-detail">Hosur-Malur Main Road, Alambady, Malur, Karnataka - 563160</div>
        </div>
      </div>

      <div class="exam-block">
        <div class="exam-title"><%= @paper.title.to_s.upcase %></div>
        <div class="exam-subject"><%= @paper.subject.name.to_s.upcase %></div>
      </div>

      <div class="paper-meta">
        <span>Time: <%= paper_duration_text(@paper) %></span>
        <span>Max Marks: <%= paper_total_marks_text(@paper) %></span>
      </div>
    </div>

    <% if @paper.instructions.present? %>
      <div class="paper-instructions">
        <div class="paper-instructions-label">Instructions:</div>
        <div class="instruction-text"><%= @paper.instructions %></div>
      </div>
    <% end %>

    <section class="paper-section">
      <div class="section-title">Section- A</div>
      <div class="section-note-row">
        <div class="section-note">Answer all questions. Each question carries 2 marks.</div>
        <div class="section-distribution"><%= paper_section_distribution(@section_a_questions.count, 2) %></div>
      </div>
      <ol class="question-list">
        <% @section_a_questions.each do |q| %>
          <li class="question-item">
            <div class="q-content"><%= h(paper_question_text(q)) %></div>
          </li>
        <% end %>
      </ol>
    </section>

    <section class="paper-section">
      <div class="section-title">Section- B</div>
      <div class="section-note-row">
        <div class="section-note">Answer all questions. Each question carries 6 marks.</div>
        <div class="section-distribution"><%= paper_section_distribution(@section_b_questions.count, 6) %></div>
      </div>
      <ol class="question-list">
        <% @section_b_questions.each do |q| %>
          <li class="question-item">
            <div class="q-content"><%= h(paper_question_text(q)) %></div>
          </li>
        <% end %>
      </ol>
    </section>

    <section class="paper-section">
      <div class="section-title">Section- C</div>
      <div class="section-note-row">
        <div class="section-note">Answer all questions. Each question carries 8 marks.</div>
        <div class="section-distribution"><%= paper_section_distribution(@section_c_questions.count, 8) %></div>
      </div>
      <ol class="question-list">
        <% @section_c_questions.each do |q| %>
          <li class="question-item">
            <div class="q-content"><%= h(paper_question_text(q)) %></div>
          </li>
        <% end %>
      </ol>
    </section>
  </article>
</section>

<style>
  .paper-frame {
    width: 210mm;
    min-height: 297mm;
    margin: 0 auto;
    padding: 40px 48px 40px;
    background: white;
    color: black;
    font-family: "Times New Roman", Times, serif;
  }

  .paper-top-band {
    height: 18px;
    margin-bottom: 16px;
    border-bottom: 1px solid #d4d4d8;
  }

  .paper-head {
    text-align: center;
    margin-bottom: 22px;
  }

  .institution-brand {
    display: flex;
    justify-content: center;
  }

  .brand-copy {
    text-align: center;
    width: 100%;
  }

  .institution-name {
    font-size: 22px;
    font-weight: 700;
    line-height: 1.2;
    color: #000000;
    letter-spacing: 0.02em;
    max-width: 100%;
    margin: 0 auto;
    text-align: center;
    word-break: break-word;
  }

  .institution-detail {
    font-size: 12px;
    line-height: 1.25;
  }

  .exam-block {
    margin-top: 18px;
  }

  .exam-title,
  .exam-subject {
    font-size: 17px;
    font-weight: 700;
    line-height: 1.5;
  }

  .paper-meta {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    margin-top: 8px;
    font-size: 17px;
    font-weight: 700;
    text-align: left;
  }

  .paper-instructions {
    margin: 0 0 20px;
    font-size: 15px;
    line-height: 1.45;
    text-align: left;
  }

  .paper-instructions-label {
    font-weight: 700;
  }

  .instruction-text {
    white-space: pre-wrap;
  }

  .paper-section {
    margin-top: 8px;
  }

  .section-title {
    font-size: 16px;
    font-weight: 700;
    margin: 12px 0 8px;
    text-align: center;
  }

  .section-note-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 6px;
  }

  .section-note,
  .section-distribution {
    font-size: 14px;
    line-height: 1.4;
    white-space: nowrap;
    font-weight: 700;
  }

  .section-distribution {
    text-align: right;
  }

  .question-list {
    margin: 0;
    padding-left: 26px;
  }

  .question-item {
    margin-bottom: 8px;
    line-height: 1.45;
    font-size: 14px;
    padding-left: 4px;
  }

  .q-content {
    white-space: pre-wrap;
  }

  @media print {
    .no-print { display: none !important; }
    body { background: white !important; padding: 0 !important; }
    .print-shell { padding: 0 !important; margin: 0 !important; }
    .paper-frame { box-shadow: none !important; width: 100% !important; padding: 38px 40px 32px !important; }
    @page { margin: 1.8cm 1cm 1.2cm; }
  }

  .paper-actions {
    background: #f8fafc;
    border-bottom: 1px solid #e2e8f0;
    padding: 15px;
    display: flex;
    gap: 15px;
    justify-content: center;
    position: sticky;
    top: 0;
    z-index: 100;
  }
</style>
