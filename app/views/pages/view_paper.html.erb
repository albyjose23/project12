<% content_for :title, "View Paper | QPaper" %>

<section class="print-shell">
  <div class="paper-actions no-print">
    <%= link_to "Back to Dashboard", pages_dashboard_path, class: "btn-ghost interactive" %>
    <button type="button" class="btn interactive" onclick="window.print()">Print or Save PDF</button>
  </div>

  <article class="paper-frame">
    <div class="paper-head">
      <h1 class="institute-name">INSTITUTE OF HIGHER EDUCATION</h1>
      <h2 class="exam-title"><%= @paper.title.upcase %></h2>
      <div class="paper-subhead">
        <strong>Subject:</strong> <%= @paper.subject.name %> (<%= @paper.subject.code %>)
      </div>
      
      <div class="paper-meta">
        <div class="meta-row">
          <%# Pulling these from subject because Paper no longer stores them %>
          <span><strong>Dept:</strong> <%= @paper.subject.try(:department) || "Computer Science" %></span>
          <span><strong>Type:</strong> <%= @paper.exam_type %></span>
        </div>
        <div class="meta-row">
          <span><strong>Time:</strong> 3 Hours</span>
          <span><strong>Max Marks:</strong> 100</span>
        </div>
      </div>
    </div>

    <%# --- Part A --- %>
    <section class="paper-section">
      <div class="section-header">
        <h3>PART A — Short Answer Questions</h3>
        <span class="marks-note">Answer ALL questions</span>
      </div>
      <ol class="question-list">
        <% @paper.questions.where(difficulty: 'Easy').each do |q| %>
          <li class="question-item">
            <div class="q-content"><%= q.content %></div>
            <div class="q-marks">[<%= q.try(:marks) || 2 %>]</div>
          </li>
        <% end %>
      </ol>
    </section>

    <%# --- Part B --- %>
    <section class="paper-section">
      <div class="section-header">
        <h3>PART B — Descriptive Questions</h3>
        <span class="marks-note">Answer any FIVE questions</span>
      </div>
      <ol class="question-list" start="<%= @paper.questions.where(difficulty: 'Easy').count + 1 %>">
        <% @paper.questions.where(difficulty: 'Medium').each do |q| %>
          <li class="question-item">
            <div class="q-content"><%= q.content %></div>
            <div class="q-marks">[<%= q.try(:marks) || 10 %>]</div>
          </li>
        <% end %>
      </ol>
    </section>

    <%# --- Part C --- %>
    <section class="paper-section">
      <div class="section-header">
        <h3>PART C — Analytical Questions</h3>
        <span class="marks-note">Case Study / Problem Solving</span>
      </div>
      <ol class="question-list" start="<%= @paper.questions.where(difficulty: ['Easy', 'Medium']).count + 1 %>">
        <% @paper.questions.where(difficulty: 'Hard').each do |q| %>
          <li class="question-item">
            <div class="q-content"><%= q.content %></div>
            <div class="q-marks">[<%= q.try(:marks) || 20 %>]</div>
          </li>
        <% end %>
      </ol>
    </section>

    <div class="paper-footer">
      <div class="signature-line">Subject Expert Signature</div>
      <div class="signature-line">Controller of Examination</div>
    </div>
  </article>
</section>

<%# Note: Keep your existing <style> block here %>

<style>
  /* Quick Inline Styles for the Paper */
  .paper-frame { padding: 40px; background: white; color: black; font-family: "Times New Roman", Times, serif; }
  .paper-head { text-align: center; border-bottom: 2px solid black; margin-bottom: 20px; padding-bottom: 10px; }
  .institute-name { font-size: 24px; font-weight: bold; margin-bottom: 5px; }
  .paper-meta { display: flex; flex-direction: column; margin-top: 15px; border-top: 1px solid #000; padding-top: 5px; }
  .meta-row { display: flex; justify-content: space-between; font-size: 14px; margin-bottom: 2px; }
  
  .section-header { display: flex; justify-content: space-between; align-items: flex-end; border-bottom: 1px solid black; margin: 20px 0 10px; }
  .section-header h3 { font-size: 16px; font-weight: bold; margin: 0; }
  .marks-note { font-style: italic; font-size: 13px; }

  .question-list { padding-left: 25px; }
  .question-item { display: flex; justify-content: space-between; margin-bottom: 15px; line-height: 1.5; }
  .q-content { flex: 1; padding-right: 20px; }
  .q-marks { font-weight: bold; min-width: 40px; text-align: right; }

  .paper-footer { display: flex; justify-content: space-between; margin-top: 60px; }
  .signature-line { border-top: 1px solid black; padding-top: 5px; width: 200px; text-align: center; font-size: 12px; }

  @media print {
    .no-print { display: none !important; }
    body { background: white !important; padding: 0 !important; }
    .print-shell { padding: 0 !important; margin: 0 !important; }
    .paper-frame { box-shadow: none !important; width: 100% !important; height: auto !important; }
  }
</style>